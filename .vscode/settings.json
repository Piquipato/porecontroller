{
    "latex-workshop.latex.outDir": "%DIR%/latex_build",
    
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ]
        },
        {
            "name": "copy-to-dist",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-NonInteractive",
                "-Command",
                "New-Item -ItemType Directory -Force -Path '%DIR%/dist' | Out-Null; Copy-Item '%OUTDIR%/%DOCFILE%.pdf' '%DIR%/dist/'"
            ]
        }
    ],

    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk + copy to dist",
            "tools": ["latexmk", "copy-to-dist"]
        }
    ]
}